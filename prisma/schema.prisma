generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  CUSTOMER
  ADMIN
}

enum ConversationStatus {
  OPEN
  ARCHIVED
}

enum MessageSenderType {
  OWNER
  CUSTOMER
  GUEST
  SYSTEM
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique
  passwordHash    String    @map("password_hash")
  fullName        String    @map("full_name")
  businessName    String?   @map("business_name")
  businessSlug    String?   @unique @map("business_slug")
  phone           String?
  role            UserRole  @default(OWNER)
  disabledAt      DateTime? @map("disabled_at")
  avatarUrl       String?   @map("avatar_url")
  emailVerifiedAt DateTime? @map("email_verified_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  products              Product[]
  pageViews             PageView[]
  shareEvents           ShareEvent[]
  storeSettings         StoreSettings?
  conversationsAsStore  Conversation[] @relation("StoreOwner")
  conversationsAsBuyer  Conversation[] @relation("Customer")
  messages              Message[]
  auditLogs             AuditLog[]       @relation("AuditActor")
  leadsReceived         Lead[]           @relation("LeadStore")

  @@index([role])
  @@map("users")
}

model StoreSettings {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @unique @map("user_id") @db.Uuid
  whatsAppPhone  String?  @map("whatsapp_phone")
  bannerUrl      String?  @map("banner_url")
  accentColor    String?  @map("accent_color")
  tagline        String?
  description    String?
  showChatWidget Boolean  @default(true) @map("show_chat_widget")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("store_settings")
}

model Category {
  id        String            @id @default(uuid()) @db.Uuid
  slug      String            @unique
  name      String
  createdAt DateTime          @default(now()) @map("created_at")
  products  ProductCategory[]

  @@map("categories")
}

model ProductCategory {
  productId  String @map("product_id") @db.Uuid
  categoryId String @map("category_id") @db.Uuid
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@map("product_categories")
}

model Product {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String   @map("user_id") @db.Uuid
  name               String
  price              Decimal  @db.Decimal(12, 2)
  sku                String?
  stockQuantity      Int      @default(0) @map("stock_quantity")
  lowStockThreshold  Int?     @map("low_stock_threshold")
  featured           Boolean  @default(false)
  descriptionRaw     String   @map("description_raw") @db.Text
  descriptionAi      String?  @map("description_ai") @db.Text
  captionAi          String?  @map("caption_ai") @db.Text
  imageUrls          String[] @default([]) @map("image_urls")
  isPublished        Boolean  @default(true) @map("is_published")
  createdAt          DateTime @default(now()) @map("created_at")

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  pageViews   PageView[]
  shareEvents ShareEvent[]
  categories  ProductCategory[]
  leads          Lead[]
  conversations  Conversation[]

  @@index([userId])
  @@index([featured])
  @@map("products")
}

model PageView {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  productId String?  @map("product_id") @db.Uuid
  referrer  String?
  viewedAt  DateTime @default(now()) @map("viewed_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([userId, viewedAt])
  @@index([productId])
  @@map("page_views")
}

model ShareEvent {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  productId String?  @map("product_id") @db.Uuid
  channel   String?
  createdAt DateTime @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@map("share_events")
}

model Conversation {
  id             String             @id @default(uuid()) @db.Uuid
  storeUserId    String             @map("store_user_id") @db.Uuid
  customerUserId String?            @map("customer_user_id") @db.Uuid
  guestToken     String?            @unique @map("guest_token")
  productId      String?            @map("product_id") @db.Uuid
  status         ConversationStatus @default(OPEN)
  lastMessageAt  DateTime?          @map("last_message_at")
  createdAt      DateTime           @default(now()) @map("created_at")

  storeOwner User      @relation("StoreOwner", fields: [storeUserId], references: [id], onDelete: Cascade)
  customer   User?     @relation("Customer", fields: [customerUserId], references: [id], onDelete: SetNull)
  product    Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  messages   Message[]

  @@index([storeUserId, status])
  @@index([customerUserId])
  @@index([productId])
  @@map("conversations")
}

model Message {
  id             String            @id @default(uuid()) @db.Uuid
  conversationId String            @map("conversation_id") @db.Uuid
  senderType     MessageSenderType @map("sender_type")
  senderUserId   String?           @map("sender_user_id") @db.Uuid
  body           String            @db.Text
  readAt         DateTime?         @map("read_at")
  createdAt      DateTime          @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User?        @relation(fields: [senderUserId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@map("messages")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String   @map("actor_user_id") @db.Uuid
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  actor User @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model Lead {
  id          String   @id @default(uuid()) @db.Uuid
  storeUserId String   @map("store_user_id") @db.Uuid
  productId   String?  @map("product_id") @db.Uuid
  name        String
  phone       String
  message     String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  store   User     @relation("LeadStore", fields: [storeUserId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([storeUserId, createdAt])
  @@map("leads")
}
